/**
 * Base URL for API - in production this would be set via environment variable
 */
const API_BASE_URL = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:4001';
  console.log('API_BASE_URL:', API_BASE_URL);

// Loading manager to track API request states
let activeRequestCount = 0;
const listeners: Set<(isLoading: boolean) => void> = new Set();

export const loadingManager = {
  increment: () => {
    activeRequestCount++;
    if (activeRequestCount === 1) {
      listeners.forEach(listener => listener(true));
    }
  },
  decrement: () => {
    if (activeRequestCount > 0) {
      activeRequestCount--;
      if (activeRequestCount === 0) {
        listeners.forEach(listener => listener(false));
      }
    }
  },
  subscribe: (listener: (isLoading: boolean) => void) => {
    listeners.add(listener);
    // Immediately call with current state
    listener(activeRequestCount > 0);
    return () => {
      listeners.delete(listener);
    };
  },
  isLoading: () => activeRequestCount > 0,
};

/**
 * Get token from localStorage
 */
const getToken = (): string | null => {
  if (typeof window !== 'undefined') {
    return localStorage.getItem('token');
  }
  return null;
};

/**
 * Fetch helper that handles JSON responses and errors
 */
async function fetcher<T>(endpoint: string, options: RequestInit = {}): Promise<T> {
  const url = `${API_BASE_URL}${endpoint}`;

  // Get token and add to headers if present
  const token = getToken();
  const headers = new Headers(options.headers ?? {});

  // Set Content-Type to application/json only if not sending FormData
  const isFormData = options.body instanceof FormData;
  if (!isFormData) {
    headers.set('Content-Type', 'application/json');
  }

  if (token) {
    headers.set('Authorization', `Bearer ${token}`);
  }
  console.log("Calling fetcher with URL:", url);

  // Notify loading manager of request start
  loadingManager.increment();

  try {
    const response = await fetch(url, {
      headers,
      ...options,
    });

    if (!response.ok) {
      const errorData = await response.json().catch(() => ({}));
      throw new Error(
        errorData.message ||
        `API request failed with status ${response.status}`
      );
    }

    // Handle empty responses (like DELETE)
    if (response.status === 204) {
      return {} as T;
    }

    return response.json();
  } finally {
    // Notify loading manager of request end
    loadingManager.decrement();
  }
}

/**
 * Exam-related APIs
 */
export const examsApi = {
  getAll: async (options?: {
    page?: number;
    limit?: number;
    sortBy?: string;
    sortOrder?: 'asc' | 'desc';
  }): Promise<{
    data: Exam[];
    total: number;
  }> => {
    // Build query parameters for sorting and pagination
    const params = new URLSearchParams();
    if (options?.page) params.append('page', options.page.toString());
    if (options?.limit) params.append('limit', options.limit.toString());
    if (options?.sortBy) params.append('sortBy', options.sortBy);
    if (options?.sortOrder) params.append('sortOrder', options.sortOrder);

    const endpoint = `/exams${params.toString() ? `?${params.toString()}` : ''}`;
    const response = await fetcher<any>(endpoint);

    // Handle both formats: { data: [], total: number } or just [] (if backend returns array)
    let examsArray: any[] = [];
    let total = 0;
    if (Array.isArray(response)) {
      examsArray = response;
      total = response.length;
    } else if (response && response.data) {
      examsArray = response.data;
      total = response.total ?? response.data.length;
    } else {
      examsArray = [];
      total = 0;
    }

    // Transform backend Exam format to frontend Exam format
    const exams = examsArray.map(exam => ({
      id: parseInt(exam.id.replace(/-/g, ''), 16) % 1000000,
      name: exam.name,
      fullName: exam.fullName ?? '',
      description: exam.description ?? '',
      icon: exam.icon ?? '',
      href: exam.href ?? '',
      gradient: exam.gradient ?? '',
      color: exam.color ?? '',
      sortOrder: exam.sortOrder,
      isActive: exam.isActive,
    }));

    // Apply client-side pagination
    const totalExams = exams.length;
    const page = options?.page ?? 1;
    const limit = options?.limit ?? 10;
    const startIndex = (page - 1) * limit;
    const endIndex = startIndex + limit;
    const paginatedData = exams.slice(startIndex, endIndex);

    return {
      data: paginatedData,
      total: totalExams,
    };
  },

  getById: async (id: string): Promise<Exam> => {
    const data = await fetcher<{
      id: string;
      name: string;
      fullName: string;
      description: string | null;
      icon: string | null;
      href: string | null;
      gradient: string | null;
      color: string | null;
      sortOrder: number;
      isActive: boolean
    }>(`/exams/${id}`);

    return {
      id: parseInt(id.replace(/-/g, ''), 16) % 1000000,
      name: data.name,
      fullName: data.fullName,
      description: data.description ?? '',
      icon: data.icon ?? '',
      href: data.href ?? '',
      gradient: data.gradient ?? '',
      color: data.color ?? '',
      sortOrder: data.sortOrder,
      isActive: data.isActive,
    };
  },

  create: async (data: Omit<Exam, 'id'>): Promise<Exam> => {
    const response = await fetcher<{
      id: string;
      name: string;
      fullName: string;
      description: string | null;
      icon: string | null;
      href: string | null;
      gradient: string | null;
      color: string | null;
      sortOrder: number;
      isActive: boolean
    }>('/exams', {
      method: 'POST',
      body: JSON.stringify(data),
      headers: {
        'Content-Type': 'application/json',
      },
    });

    return {
      id: parseInt(response.id.replace(/-/g, ''), 16) % 1000000,
      name: response.name,
      fullName: response.fullName,
      description: response.description ?? '',
      icon: response.icon ?? '',
      href: response.href ?? '',
      gradient: response.gradient ?? '',
      color: response.color ?? '',
      sortOrder: response.sortOrder,
      isActive: response.isActive,
    };
  },

  update: async (id: string, data: Partial<Omit<Exam, 'id'>>): Promise<Exam> => {
    const response = await fetcher<{
      id: string;
      name: string;
      fullName: string;
      description: string | null;
      icon: string | null;
      href: string | null;
      gradient: string | null;
      color: string | null;
      sortOrder: number;
      isActive: boolean
    }>(`/exams/${id}`, {
      method: 'PATCH',
      body: JSON.stringify(data),
      headers: {
        'Content-Type': 'application/json',
      },
    });

    return {
      id: parseInt(id.replace(/-/g, ''), 16) % 1000000,
      name: response.name,
      fullName: response.fullName,
      description: response.description ?? '',
      icon: response.icon ?? '',
      href: response.href ?? '',
      gradient: response.gradient ?? '',
      color: response.color ?? '',
      sortOrder: response.sortOrder,
      isActive: response.isActive,
    };
  },

  delete: async (id: string): Promise<void> => {
    await fetcher<void>(`/exams/${id}`, {
      method: 'DELETE',
    });
  },
};

