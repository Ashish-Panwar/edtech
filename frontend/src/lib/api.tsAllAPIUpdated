/**
 * Auth APIs
 */
export const authApi = {
  login: async (credentials: { email: string; password: string }): Promise<AuthResponse> => {
    const result = await fetcher<AuthResponse>('/auth/login', {
      method: 'POST',
      body: JSON.stringify(credentials),
    });
    // Store token and user
    if (typeof window !== 'undefined') {
      localStorage.setItem('token', result.accessToken);
      localStorage.setItem('user', JSON.stringify(result.user));
    }
    return result;
  },

  register: async (userData: { name: string; email: string; password: string }): Promise<AuthResponse> => {
    const result = await fetcher<AuthResponse>('/auth/register', {
      method: 'POST',
      body: JSON.stringify(userData),
    });
    return result;
  },

  logout: async (): Promise<void> => {
    // Call backend logout endpoint requires token; we will fetch then clear token
    try {
      await fetcher<void>('/auth/logout', {
        method: 'POST',
      });
    } catch (error) {
      // Ignore errors on logout
    }
    // Remove token and user on logout
    if (typeof window !== 'undefined') {
      localStorage.removeItem('token');
      localStorage.removeItem('user');
    }
  },
};