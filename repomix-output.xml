        <Swiper
          modules={[Autoplay]}
          spaceBetween={24}
          slidesPerView="auto"
          autoplay={{ delay: 5000, disableOnInteraction: false }}
          speed={700}
          loop
          className="!px-4 sm:!px-6 lg:!px-8"
        >
          {courses.map((course: any, index: number) => (
            <SwiperSlide
              key={course.id}
              className="!w-[300px] md:!w-[350px] lg:!w-[calc(25%-18px)]"
