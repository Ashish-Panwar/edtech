                type="submit"
                className="w-full"
                disabled={loading}
              >
                {loading ? "Submitting..." : "Submit Enquiry"}
              </Button>

              <p className="text-xs text-slate/60 text-center">
                We respect your privacy. Your data is secure and will not be
                shared with third parties.
